# ─── Supabase ─────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── LLMs ─────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5
OPENAI_API_KEY=
OPENAI_CLASSIFIER_MODEL=gpt-4o-mini

# ─── Auth ─────────────────────────────────────────────────────────
# AUTH_SECRET: 32-byte hex (generate with: openssl rand -hex 32)
AUTH_SECRET=
DASHBOARD_PASSWORD=
# API_SECRET: for programmatic access via x-api-secret header (openssl rand -hex 32)
API_SECRET=

# ─── Telegram ─────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_USER_ID=

# ─── Google (Finance: service account; Calendar: OAuth refresh token) ─
GOOGLE_CALENDAR_ICAL_URL=
GOOGLE_SHEETS_FINANCE_ID=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_KEY=
# Calendar push (port from command-center)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
CALENDAR_ID=primary

# ─── Cron ─────────────────────────────────────────────────────────
CRON_SECRET=

# ─── User config ──────────────────────────────────────────────────
USER_TIMEZONE=America/Los_Angeles
USER_ID=desean
